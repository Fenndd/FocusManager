<Page
    x:Class="FocusManager.App.Views.AppsWhitelistPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="24">
        <StackPanel Spacing="8">
            <TextBlock Text="Applications Whitelist" FontSize="24" FontWeight="SemiBold" />
            <TextBlock Text="Stub page: add/remove allowed executable paths." />
            <ListView x:Name="AllowedAppsList" Height="300" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Add" />
                <Button Content="Remove" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
